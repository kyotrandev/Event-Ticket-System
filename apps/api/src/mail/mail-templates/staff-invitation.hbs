<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
</head>
<body style="margin: 0; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; background-color: #f4f4f4; color: #333333;">
    <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #f4f4f4; padding: 20px;">
        <tr>
            <td align="center">
                <table width="600" cellpadding="0" cellspacing="0" style="background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                    <tr>
                        <td style="padding: 40px; text-align: center; background-color: #000000; color: #ffffff;">
                            <h1 style="margin: 0; font-size: 24px; font-weight: 600;">{{app_name}}</h1>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 40px;">
                            <h2 style="margin-top: 0; font-size: 20px; color: #333;">You have been invited!</h2>
                            <p style="font-size: 16px; line-height: 1.5; color: #555;">
                                <strong>{{organizerName}}</strong> has invited you to be a Staff member for the event <strong>{{eventName}}</strong> on {{app_name}}.
                            </p>
                            <p style="font-size: 16px; line-height: 1.5; color: #555;">
                                To accept the invitation and activate your account, please set your password by clicking the button below:
                            </p>
                            <div style="text-align: center; margin: 30px 0;">
                                <a href="{{url}}" style="display: inline-block; padding: 14px 28px; background-color: #000000; color: #ffffff; text-decoration: none; border-radius: 6px; font-size: 16px; font-weight: bold;">{{actionTitle}}</a>
                            </div>
                            <p style="font-size: 14px; line-height: 1.5; color: #777;">
                                If you did not expect this invitation, you can safely ignore this email.
                            </p>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 20px; text-align: center; background-color: #f9f9f9; font-size: 12px; color: #999;">
                            <p style="margin: 0;">&copy; {{app_name}}. All rights reserved.</p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
